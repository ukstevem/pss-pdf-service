# pss-pdf-service — environment variables
# Copy to .env for local dev. NEVER commit .env.

# HTTP port (internal service — no gateway route; see platform-portal/docs/PORTS.md)
PORT=8017

# Shared API key callers must send as X-Api-Key. Generate a long random value.
PDF_SERVICE_API_KEY=

# Upper bound on accepted HTML payload (bytes)
MAX_HTML_BYTES=2000000

# Per-render timeout (ms)
RENDER_TIMEOUT_MS=30000
